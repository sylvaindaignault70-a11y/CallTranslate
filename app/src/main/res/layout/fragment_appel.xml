<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080810"
    android:clipToPadding="false"
    android:paddingBottom="160dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌐 TRADUCTION APPEL"
            android:textColor="#7c3aed"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="MOI" android:textColor="#94a3b8" android:textSize="11sp" android:minWidth="48dp"/>
            <Spinner android:id="@+id/spinCallMoi" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:background="#0f0f1a"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AUTRE" android:textColor="#94a3b8" android:textSize="11sp" android:minWidth="48dp"/>
            <Spinner android:id="@+id/spinCallOther" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:background="#0f0f1a"/>
        </LinearLayout>

        <Button android:id="@+id/btnCallTrad"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="▶ Démarrer traduction" android:backgroundTint="#10b981"
            android:textColor="#ffffff" android:gravity="start|center_vertical"
            android:paddingStart="16dp" android:layout_marginBottom="6dp"
                android:maxLines="1"/>

        <TextView android:id="@+id/tvCallStatus"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Arrêté" android:textColor="#64748b" android:textSize="12sp"
            android:gravity="center" android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#0f0f1a" android:padding="8dp" android:layout_marginEnd="4dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="🔊 L'AUTRE" android:textColor="#64748b" android:textSize="10sp"
                    android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvCallOriginal"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="—" android:textColor="#e2e8f0" android:textSize="13sp"
                    android:minHeight="56dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#0f0f1a" android:padding="8dp" android:layout_marginStart="4dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="🌐 TRADUCTION" android:textColor="#64748b" android:textSize="10sp"
                    android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvCallResult"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="—" android:textColor="#06b6d4" android:textSize="13sp"
                    android:minHeight="56dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Section Contacts -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 CONTACTS"
            android:textColor="#7c3aed"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="6dp">
            <Button android:id="@+id/btnContacts"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:text="📋 Contacts" android:backgroundTint="#1a1a2e" android:textColor="#e2e8f0"
                android:layout_marginEnd="6dp" android:maxLines="1"/>
            <Button android:id="@+id/btnVider"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:text="Vider" android:backgroundTint="#1a1a2e" android:textColor="#64748b"
                android:maxLines="1"/>
        </LinearLayout>

        <TextView android:id="@+id/tvContactNum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#e2e8f0"
            android:textSize="13sp"
            android:background="#0f0f1a"
            android:padding="8dp"
            android:layout_marginBottom="6dp"/>

        <EditText android:id="@+id/etNumero"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="Numéro manuel"
            android:inputType="phone"
            android:textColor="#e2e8f0"
            android:textColorHint="#64748b"
            android:background="#0f0f1a"
            android:paddingStart="12dp"
            android:layout_marginBottom="6dp"/>

        <Button android:id="@+id/btnSignaler"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📞 Signaler"
            android:backgroundTint="#7c3aed"
            android:textColor="#ffffff"
            android:layout_marginBottom="12dp"
            android:maxLines="1"/>

        <Button android:id="@+id/btnCallRec"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="⏺ Rec" android:backgroundTint="#ef4444" android:textColor="#ffffff"
            android:gravity="start|center_vertical" android:paddingStart="12dp"
            android:layout_marginBottom="12dp"
            android:maxLines="1"/>

        <Button android:id="@+id/btnRaccrocheur"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="📵 Raccrocher" android:backgroundTint="#7f1d1d" android:textColor="#fca5a5"
            android:layout_marginBottom="8dp" android:maxLines="1"/>

        <Button android:id="@+id/btnCallSave"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="💾 Sauvegarder" android:backgroundTint="#1a1a2e" android:textColor="#06b6d4"
            android:gravity="start|center_vertical" android:paddingStart="16dp"
            android:layout_marginTop="8dp" android:maxLines="1"/>

        <!-- DEBUG panel -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="12dp" android:layout_marginBottom="4dp"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="🐛 DEBUG" android:textColor="#f59e0b" android:textSize="12sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="RMS:" android:textColor="#64748b" android:textSize="11sp"/>
            <TextView android:id="@+id/tvAppelRms"
                android:layout_width="48dp" android:layout_height="wrap_content"
                android:text="0.0" android:textColor="#f59e0b" android:textSize="11sp"
                android:gravity="end" android:layout_marginStart="4dp" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnAppelDebugClear"
                android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="Effacer" android:backgroundTint="#1a1a2e" android:textColor="#64748b"
                android:textSize="10sp" android:paddingStart="10dp" android:paddingEnd="10dp"/>
        </LinearLayout>

        <ProgressBar android:id="@+id/pbAppelRms"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#f59e0b"
            android:layout_marginBottom="4dp"/>

        <ScrollView android:id="@+id/scrollAppelDebug"
            android:layout_width="match_parent" android:layout_height="200dp"
            android:background="#0f0f1a" android:padding="8dp">
            <TextView android:id="@+id/tvAppelDebugLog"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#94a3b8" android:textSize="11sp"
                android:fontFamily="monospace" android:lineSpacingExtra="3dp"/>
        </ScrollView>

    </LinearLayout>
</ScrollView>
