<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080810"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎚️ ÉGALISEUR"
        android:textColor="#7c3aed"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="12dp"/>

    <HorizontalScrollView android:id="@+id/scrollPresets"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">
        <LinearLayout android:id="@+id/presetContainer"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <LinearLayout android:id="@+id/bandsContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="bottom"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="12dp">
        <Button android:id="@+id/btnResetEQ"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:text="↺ Flat" android:backgroundTint="#1a1a2e" android:textColor="#e2e8f0"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnSaveEQ"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:text="💾 Sauvegarder" android:backgroundTint="#1a1a2e" android:textColor="#10b981"/>
    </LinearLayout>

    <TextView android:id="@+id/tvEQStatus"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Lance la musique d'abord" android:textColor="#64748b"
        android:textSize="12sp" android:gravity="center" android:layout_marginTop="8dp"/>

</LinearLayout>
